GITHUB_TOKEN=ghp_replace_with_a_readonly_token

# Optional comma-separated allowlist. Leave empty to allow any repository.
# Example: Cosmess/mcp-github-pr-reviewer,Cosmess/another-repo
ALLOWED_REPOSITORIES=

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TIMEOUT_SECONDS=20
MAX_PATCH_CHARS=120000
ENABLE_GITHUB_WRITE_ACTIONS=false

# Optional OpenAI-compatible LLM analyzer.
LLM_ANALYZER_ENABLED=false
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_PATCH_CHARS=40000
